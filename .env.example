SECRET_KEY=troque-por-uma-chave-aleatoria

# Local (SQLite):
# DATABASE_URL=sqlite:///instance/diario.db

# Produção (PostgreSQL / EasyPanel):
# DATABASE_URL=postgresql://usuario:senha@postgres:5432/diario

PORT=8000
UPLOAD_FOLDER=/app/uploads

# Bootstrap — cria o primeiro nutricionista se o banco estiver vazio
# ADMIN_EMAIL=admin@exemplo.com
# ADMIN_PASSWORD=senha-segura-min-8-chars
# ADMIN_NAME=Administrador

# IA — registro por voz e foto (OpenAI)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_WHISPER_MODEL=whisper-1
